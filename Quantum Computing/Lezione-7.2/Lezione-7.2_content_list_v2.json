[
    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "16 Lecture 16: Complexity"
                    }
                ],
                "level": 2
            },
            "bbox": [
                139,
                121,
                549,
                144
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "16.1 Asymptotic notation"
                    }
                ],
                "level": 2
            },
            "bbox": [
                139,
                159,
                468,
                180
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "A notation that captures the essential behaviour of a function for large values of its variable."
                    }
                ]
            },
            "bbox": [
                137,
                187,
                857,
                220
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1) "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f ( n ) = O ( g ( n ) )"
                            },
                            {
                                "type": "text",
                                "content": ") if there exists a "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n _ { 0 }"
                            },
                            {
                                "type": "text",
                                "content": "such that for any "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n > n _ { 0 } \\ , f ( n ) \\leq c \\ g ( n )"
                            },
                            {
                                "type": "text",
                                "content": "with "
                            },
                            {
                                "type": "equation_inline",
                                "content": "c = { \\mathrm { c o n s t a n t } } ."
                            },
                            {
                                "type": "text",
                                "content": "."
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2) "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f ( n ) = \\Omega ( g ( n ) )"
                            },
                            {
                                "type": "text",
                                "content": "if there exists a "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n _ { 0 }"
                            },
                            {
                                "type": "text",
                                "content": "such that for any "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n > n _ { 0 } \\ , f ( n ) \\geq c \\ g ( n )"
                            },
                            {
                                "type": "text",
                                "content": "with c = constant."
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "3) "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f ( n ) = \\Theta ( g ( n ) )"
                            },
                            {
                                "type": "text",
                                "content": "if f (n) and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g ( n )"
                            },
                            {
                                "type": "text",
                                "content": "have the same asymptotic behaviour up to a constant factor. If "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f ( n ) = O ( g ( n ) ) = \\Omega ( g ( n ) )"
                            },
                            {
                                "type": "text",
                                "content": "then "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f ( n ) = \\Theta ( g ( n ) )"
                            },
                            {
                                "type": "text",
                                "content": "."
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                137,
                233,
                855,
                366
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Examples:"
                    }
                ],
                "level": 2
            },
            "bbox": [
                139,
                378,
                247,
                395
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "<sub>•</sub> 2n is "
                            },
                            {
                                "type": "equation_inline",
                                "content": "O ( n ^ { 2 } ) , 2 ^ { n } \\ \\mathrm { i s } \\ \\Omega ( n ^ { 3 } )"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "• "
                            },
                            {
                                "type": "equation_inline",
                                "content": "7 n ^ { 2 } + { \\sqrt { n } } \\log n"
                            },
                            {
                                "type": "text",
                                "content": "is "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\Theta ( n ^ { 2 } )"
                            },
                            {
                                "type": "text",
                                "content": "since "
                            },
                            {
                                "type": "equation_inline",
                                "content": "7 n ^ { 2 } \\leq 7 n ^ { 2 } + { \\sqrt { n } } \\log n \\leq 8 n ^ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": "for n su\u0000ciently large."
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "equation_inline",
                                "content": "\\bullet f ( n ) = O ( g ( n ) ) \\Leftrightarrow g ( n ) = \\Omega ( f ( n ) ) , f ( n ) = \\Theta ( g ( n ) ) \\Leftrightarrow g ( n ) = \\Theta ( f ( n ) ) ."
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "<sub>•</sub> if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g ( n )"
                            },
                            {
                                "type": "text",
                                "content": "is a polynomial of order k, "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g ( n ) = O ( n ^ { l } )"
                            },
                            {
                                "type": "text",
                                "content": "for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "k \\leq l ."
                            },
                            {
                                "type": "text",
                                "content": "."
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "<sub>•</sub> log "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n = O ( n ^ { k } )"
                            },
                            {
                                "type": "text",
                                "content": "for any "
                            },
                            {
                                "type": "equation_inline",
                                "content": "k > 0"
                            },
                            {
                                "type": "text",
                                "content": "."
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "• "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n ^ { \\log n }"
                            },
                            {
                                "type": "text",
                                "content": "is superpolynomial: "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n ^ { k } = O ( n ^ { \\log n } )"
                            },
                            {
                                "type": "text",
                                "content": "for any k, but "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n ^ { \\log n } \\neq O ( n ^ { k } )"
                            },
                            {
                                "type": "text",
                                "content": "."
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "• "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n ^ { \\log n }"
                            },
                            {
                                "type": "text",
                                "content": "is subexponential: "
                            },
                            {
                                "type": "equation_inline",
                                "content": "c ^ { n } = \\Omega ( n ^ { \\log n } )"
                            },
                            {
                                "type": "text",
                                "content": "for any "
                            },
                            {
                                "type": "equation_inline",
                                "content": "c > 1"
                            },
                            {
                                "type": "text",
                                "content": ", but "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n ^ { \\log n } \\neq \\Omega ( c ^ { n } )"
                            },
                            {
                                "type": "text",
                                "content": "."
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "<sub>•</sub> if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "e ( n ) = O ( f ( n ) )"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g ( n ) = O { \\bigl ( } h ( n ) { \\bigr ) }"
                            },
                            {
                                "type": "text",
                                "content": ", then "
                            },
                            {
                                "type": "equation_inline",
                                "content": "e ( n ) g ( n ) = O ( f ( n ) h ( n ) )"
                            },
                            {
                                "type": "text",
                                "content": "."
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                137,
                408,
                855,
                642
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Exercise: : show that ordering n names alphabetically is ⌦(n log n). Since algorithms are known, that are "
                    },
                    {
                        "type": "equation_inline",
                        "content": "O ( n \\log n )"
                    },
                    {
                        "type": "text",
                        "content": ", the ordering problem is "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Theta ( n \\log n )"
                    },
                    {
                        "type": "text",
                        "content": "."
                    }
                ]
            },
            "bbox": [
                137,
                654,
                857,
                688
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "16.2 Computational complexity"
                    }
                ],
                "level": 2
            },
            "bbox": [
                139,
                711,
                537,
                731
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Easy problems: solution can be found in polynomial time, i.e. with a number of steps that is a polynomial function of the dimension n of the input. For example the addition of two "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n { \\mathrm { - } } \\mathrm { b i t }"
                    },
                    {
                        "type": "text",
                        "content": "integers scales as n."
                    }
                ]
            },
            "bbox": [
                137,
                739,
                858,
                790
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Hard problems: superpolynomial in n. For example the factorization of an integer N requires a number of steps scaling as exp n, if n is the number of digits of N ."
                    }
                ]
            },
            "bbox": [
                139,
                804,
                857,
                839
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": [
                    {
                        "type": "text",
                        "content": "73"
                    }
                ]
            },
            "bbox": [
                487,
                906,
                510,
                919
            ]
        }
    ],
    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "The main complexity classes are:"
                    }
                ]
            },
            "bbox": [
                139,
                125,
                430,
                142
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "P: problems that can be solved in polynomial time (easy problems)."
                    }
                ]
            },
            "bbox": [
                166,
                156,
                761,
                173
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "NP: problems whose solution can be verified in polynomial time."
                    }
                ]
            },
            "bbox": [
                166,
                174,
                736,
                188
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "NP-complete: any NP problem can be reduced to a NP-complete problem."
                    }
                ]
            },
            "bbox": [
                166,
                190,
                833,
                207
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Obviously NP includes P. No proof exists, but it is generally believed that NP = P. If a polynomial-time resolution of a NP-complete problem was ever found, any NP problem could be solved in polynomial time, which would imply "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathrm { P = N P }"
                    },
                    {
                        "type": "text",
                        "content": ". The current consensus is that no polynomial time resolution of a NP-complete problem exists."
                    }
                ]
            },
            "bbox": [
                137,
                220,
                855,
                306
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "For example integer factorization is NP, since the solution can be checked (by multiplication) in polynomial time. However no polynomial time factorization algorithm is known within classical computation. The situation changes with quantum computation: the Shor algorithm, based on the quantum Fourier transform (see Lecture 23), factorizes in polynomial time. Unfortunatley the factorizing problem is not NP-complete, so that we cannot conclude "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathrm { P = N P }"
                    },
                    {
                        "type": "text",
                        "content": "within quantum computation."
                    }
                ]
            },
            "bbox": [
                137,
                320,
                855,
                423
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "16.3 Examples"
                    }
                ],
                "level": 2
            },
            "bbox": [
                139,
                445,
                334,
                465
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "<sub>•</sub> A graph is a finite collection of vertices "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ v _ { 1 } , . . . v _ { n } \\}"
                    },
                    {
                        "type": "text",
                        "content": ", connected by links "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( v _ { i } , v _ { j } )"
                    },
                    {
                        "type": "text",
                        "content": ". The graph is non-directional if the order of the vertices in the links is irrelevant. A cycle is a sequence of vertices "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ v _ { 1 } , . . . v _ { m } \\}"
                    },
                    {
                        "type": "text",
                        "content": "such that every pair "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( v _ { j } , v _ { j + 1 } )"
                    },
                    {
                        "type": "text",
                        "content": "is a link and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( v _ { m } , v _ { 1 } )"
                    },
                    {
                        "type": "text",
                        "content": "is a link. In words, a cycle is a closed path in the graph."
                    }
                ]
            },
            "bbox": [
                137,
                473,
                855,
                542
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "A cycle is simple if all its vertices appear only once."
                    }
                ]
            },
            "bbox": [
                168,
                543,
                620,
                558
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "A cycle is Hamiltonian if it is simple and includes all the vertices of the graph."
                    }
                ]
            },
            "bbox": [
                168,
                559,
                850,
                576
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "A cycle is Eulerian if every link of the graph is “visited” only once."
                    }
                ]
            },
            "bbox": [
                168,
                577,
                752,
                593
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Given a graph, no polynomial algorithm is known to decide whether it admits a Hamiltonian cycle. Moreover the Hamiltonian cycle (HC) problem can be shown to be NP-complete."
                    }
                ]
            },
            "bbox": [
                137,
                606,
                855,
                657
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Perhaps surprisingly, the Eulerian cycle (EC) problem is in class P. In fact, a graph admits an Eulerian cycle if it is connected and only an even number of lines originate from every vertex of the graph, a result due to Euler. Checking that it is connected requires "
                    },
                    {
                        "type": "equation_inline",
                        "content": "O ( n ^ { 2 } )"
                    },
                    {
                        "type": "text",
                        "content": "operations, and checking the number of incident lines for every vertex requires "
                    },
                    {
                        "type": "equation_inline",
                        "content": "O ( n ^ { 3 } )"
                    },
                    {
                        "type": "text",
                        "content": "operations (there are at most "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n ( n - 1 ) / 2"
                    },
                    {
                        "type": "text",
                        "content": "lines in the graph with n vertices). Thus EC is in class P."
                    }
                ]
            },
            "bbox": [
                137,
                672,
                855,
                776
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": [
                    {
                        "type": "text",
                        "content": "74"
                    }
                ]
            },
            "bbox": [
                487,
                904,
                510,
                919
            ]
        }
    ],
    [
        {
            "type": "image",
            "content": {
                "image_source": {
                    "path": "images/527949056600e09cc3985c47b13c2e5ca8cad5d95776bfdbdeb25a58999fe3a1.jpg"
                },
                "content": "```mermaid\ngraph LR\n  1[\"1\"] --> 2[\"2\"]\n  2 -.-> 5[\"5\"]\n  3[\"3\"] --> 4[\"4\"]\n  n4[\"4\"] --> n5[\"5\"]\n```",
                "image_caption": [
                    {
                        "type": "text",
                        "content": "Fig. 16.1 Without the dashed line, this graph has no Hamiltonian cycle, but has a Eulerian cycle. With the dashed line, there is a Hamiltonian cycle, but no Eulerian cycle."
                    }
                ],
                "image_footnote": []
            },
            "sub_type": "flowchart",
            "bbox": [
                233,
                135,
                497,
                287
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Both HC and EC are examples of decisional problems: an algorithm solving the problem anwers yes or no to the question of existence of particular cycles."
                    }
                ]
            },
            "bbox": [
                137,
                353,
                855,
                387
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "<sub>•</sub> The Traveling Salesman Problem (TSP) is another NP-complete decisional problem, and is formulated as follows:"
                    }
                ]
            },
            "bbox": [
                137,
                401,
                853,
                434
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "“Given n towns and a distance "
                    },
                    {
                        "type": "equation_inline",
                        "content": "d _ { i j }"
                    },
                    {
                        "type": "text",
                        "content": "between town i and town "
                    },
                    {
                        "type": "equation_inline",
                        "content": "j ,"
                    },
                    {
                        "type": "text",
                        "content": "is there a closed path including all towns with total length "
                    },
                    {
                        "type": "equation_inline",
                        "content": "< d : \\mathbf { \\Omega } ^ { \\prime }"
                    }
                ]
            },
            "bbox": [
                137,
                435,
                855,
                469
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "We now prove that HC reduces to TSP. It su\u0000ces to apply TSP with the following specifications: if the graph has n vertices, each vertex is considered a town, and the distance "
                    },
                    {
                        "type": "equation_inline",
                        "content": "d _ { i j }"
                    },
                    {
                        "type": "text",
                        "content": "beween towns is assigned to be 1 if the corresponding vertices in the graph are connected by a link, and 2 otherwise. Then with TSP we can answer the question: does a closed path connecting all towns exist, with length "
                    },
                    {
                        "type": "equation_inline",
                        "content": "< n + 1 \\ ?"
                    },
                    {
                        "type": "text",
                        "content": ". An algorithm solving TSP will provide the answer: if positive, it implies that such a path exists, and its length is n (it must be "
                    },
                    {
                        "type": "equation_inline",
                        "content": "< n + 1"
                    },
                    {
                        "type": "text",
                        "content": "and, since the closed path connects n towns, it must be at least n). Then a Hamiltonian cycle exists in the graph, including all its vertices only once."
                    }
                ]
            },
            "bbox": [
                137,
                483,
                855,
                637
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Thus, given an algorithm that solves TSP, it can be converted to an algorithm that solves HC. Since HC is NP-complete, this implies that also TSP is NP-complete: if every NP problem reduces to HC, it also reduces to TSP."
                    }
                ]
            },
            "bbox": [
                137,
                638,
                855,
                688
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "<sub>•</sub> CSAT (circuit satisfybility) is the decisional problem: “Given a boolean circuit composed by AND, OR, NOT gates, does an input assignment exist that gives as output the bit "
                            },
                            {
                                "type": "equation_inline",
                                "content": "1 ? \\ : \\ \""
                            },
                            {
                                "type": "text",
                                "content": ". This problem can be shown (Cook-Levin proof) to be NPcomplete, by use of the Turing machine paradigm, see for ex. Chuang and Nielsen, p.146. Thus if a problem is NP, and CSAT reduces to it, the problem is also NPcomplete. In this way many other problems have been shown to be NP-complete."
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "SUBSET SUM is another NP-complete problem, well suited to be attacked also by quantum computing protocols. It consists in finding whether a subset exists, in a list of integers "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( n _ { 1 } , . . . n _ { N } )"
                            },
                            {
                                "type": "text",
                                "content": ", having as sum a given integer S."
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                137,
                701,
                855,
                871
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": [
                    {
                        "type": "text",
                        "content": "75"
                    }
                ]
            },
            "bbox": [
                487,
                906,
                509,
                919
            ]
        }
    ],
    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Note: no quantum protocol is known to solve in polynomial time NP-complete problems. It is widely believed that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathrm { P \\neq N P }"
                    },
                    {
                        "type": "text",
                        "content": "also within quantum computation."
                    }
                ]
            },
            "bbox": [
                137,
                125,
                857,
                161
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "16.4 Energy and information"
                    }
                ],
                "level": 2
            },
            "bbox": [
                139,
                182,
                505,
                201
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Energy requirements for computation are related to reversibility. In irreversible gates, as for example the classical NAND gate, there is loss of information. To cancel information, energy is required, as stated in Landauer’s principle (1961):"
                    }
                ]
            },
            "bbox": [
                137,
                210,
                858,
                263
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "To cancel 1 bit, an energy of at least kT log 2 is required."
                    }
                ]
            },
            "bbox": [
                139,
                275,
                636,
                293
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "This principle can be justified by considering the encoding of 1 bit by using a gas in a box. The gas is very peculiar, consisting of only one molecule. The box is divided into two parts, with a mobile partition. As such, the box contains 1 bit of information, which has value 0 if the molecule is on left of the partition, and value 1 if on the right of the partition. Suppose we want to cancel this information: we remove the partition and compress the gas to the left with a piston, which slides halfway into the box. Now the molecule will be located with certainty in the left part of the box, and carries no information. A bit has been cancelled. But work was necessary to compress the gas. This work can be computed by considering the entropy of the system before and after compression. In the initial state, the box had entropy S = k log(number of microstates) = k log 2, since there are two possible microstates (molecule on the left, molecule on the right). After the compression, only 1 microstate survives, and the box has entropy = 0. Thus the box entropy has decreased by "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Delta S = k \\log 2"
                    },
                    {
                        "type": "text",
                        "content": ", which corresponds to a work "
                    },
                    {
                        "type": "equation_inline",
                        "content": "W = T \\Delta S = k T \\log 2"
                    },
                    {
                        "type": "text",
                        "content": "."
                    }
                ]
            },
            "bbox": [
                142,
                306,
                858,
                547
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "16.5 Reversible classical computation: the TOFFOLI gate"
                    }
                ],
                "level": 2
            },
            "bbox": [
                139,
                568,
                853,
                589
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "The gates for a classical universal set, NAND and FANOUT , are non reversible. Information is lost: from the output we cannot reconstruct the input. Nevertheless, it is possible to simulate NAND and FANOUT with reversible gates. For example the To↵oli gate, a 3-bit to 3-bit gate, can be used as in Fig. 16.2 to act as NAND or FANOUT. Thus To↵oli by itself can be considered a universal set."
                    }
                ]
            },
            "bbox": [
                137,
                596,
                858,
                682
            ]
        },
        {
            "type": "image",
            "content": {
                "image_source": {
                    "path": "images/2c91320b8be4596352c320270d33a2944ff56a3eec8e33db600acc8c256efcc3.jpg"
                },
                "content": "a —●——— a\nb —●——— b\nc —⊕——— c ⊕ ab",
                "image_caption": [
                    {
                        "type": "text",
                        "content": "TOFFOLI"
                    }
                ],
                "image_footnote": []
            },
            "sub_type": "text_image",
            "bbox": [
                176,
                701,
                364,
                760
            ]
        },
        {
            "type": "image",
            "content": {
                "image_source": {
                    "path": "images/c1d2221596b6941a12502b4c7a54111db662b0c5f9e8f5cc8b85bebbed54dae0.jpg"
                },
                "content": "a ——●—— a\nb ——●—— b\n1 —— ⊕ —— 1 ⊕ ab",
                "image_caption": [
                    {
                        "type": "text",
                        "content": "NAND"
                    }
                ],
                "image_footnote": []
            },
            "sub_type": "text_image",
            "bbox": [
                401,
                701,
                589,
                758
            ]
        },
        {
            "type": "image",
            "content": {
                "image_source": {
                    "path": "images/cf3aa82344ef92d86e34c29e304c5b65b5b25d801d183388e77df4ab700c737f.jpg"
                },
                "content": "",
                "image_caption": [
                    {
                        "type": "text",
                        "content": "FANOUT"
                    },
                    {
                        "type": "text",
                        "content": "Fig. 16.2 The TOFFOLI gate, and its use to simulate NAND and FANOUT"
                    }
                ],
                "image_footnote": []
            },
            "bbox": [
                631,
                701,
                776,
                758
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "This shows that classical computation can be made reversible, but at the cost of introducing service bits in input (“ancilla bits”) , and producing extra bits in output (“garbage bits”). These extra bits must be cancelled at some stage, to reduce cluttering of the memory, and will require energy for their cancellation."
                    }
                ]
            },
            "bbox": [
                137,
                828,
                858,
                863
