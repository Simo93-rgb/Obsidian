                0.865,
                0.384
            ],
            "angle": 0,
            "content": "\\[\n\\begin{array}{l} Q F T | j \\rangle = \\frac {1}{2 ^ {\\frac {n}{2}}} \\sum_ {k = 0} ^ {2 ^ {n} - 1} e ^ {2 \\pi i j k / 2 ^ {n}} | k \\rangle = \\frac {1}{2 ^ {\\frac {n}{2}}} \\sum_ {k _ {1} = 0} ^ {1} \\dots \\sum_ {k _ {n} = 0} ^ {1} e ^ {2 \\pi i j / 2 ^ {n} (k _ {1} 2 ^ {n - 1} + \\dots + k _ {n} 2 ^ {0} ]} | k _ {1} \\dots k _ {n} \\rangle \\\\ = \\frac {1}{2 ^ {\\frac {n}{2}}} \\sum_ {k _ {1} = 0} ^ {1} e ^ {2 \\pi i j k _ {1} 2 ^ {- 1}} | k _ {1} \\rangle \\sum_ {k _ {2} = 0} ^ {1} e ^ {2 \\pi i j k _ {2} 2 ^ {- 2}} | k _ {2} \\rangle \\dots \\sum_ {k _ {n} = 0} ^ {1} e ^ {2 \\pi i j k _ {n} 2 ^ {- n}} | k _ {n} \\rangle \\\\ = \\frac {1}{2 ^ {\\frac {n}{2}}} (| 0 \\rangle + e ^ {2 \\pi i j / 2} | 1 \\rangle) (| 0 \\rangle + e ^ {2 \\pi i j / 2 ^ {2}} | 1 \\rangle) \\dots (| 0 \\rangle + e ^ {2 \\pi i j / 2 ^ {n}} | 1 \\rangle) \\tag {20.8} \\\\ \\end{array}\n\\]"
